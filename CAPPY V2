def create_default_configs():
    """Create default configuration files if they don't exist"""
    config_9352 = Path('config_9352.yaml')
    config_9462 = Path('config_9462.yaml')
    
    if not config_9352.exists():
        config_9352.write_text(DEFAULT_YAML_9352)
        print(f"Created default config: {config_9352}")
        
    if not config_9462.exists():
        config_9462.write_text(DEFAULT_YAML_9462)
        print(f"Created default config: {config_9462}")

def run_headless(config_9352: Path, config_9462: Path):
    """
    Run acquisition in headless mode (no GUI).
    Useful for server deployments or automated testing.
    """
    print("="*80)
    print("CAPPY DUAL-BOARD HEADLESS MODE")
    print("="*80)
    
    if not ATS_AVAILABLE:
        print("ERROR: ATS API not available!")
        return 1
        
    # Create queue for log messages
    log_queue = queue.Queue()
    
    # Create acquisition instances
    acq_9352 = BoardAcquisition('9352', config_9352, log_queue)
    acq_9462 = BoardAcquisition('9462', config_9462, log_queue)
    
    # Load configs
    acq_9352.load_config()
    acq_9462.load_config()
    
    # Start acquisitions
    print("Starting acquisitions...")
    acq_9352.start()
    acq_9462.start()
    
    print("Acquisition running. Press Ctrl+C to stop.")
    print("-"*80)
    
    # Log processing loop
    try:
        while True:
            try:
                msg = log_queue.get(timeout=1.0)
                if msg[0] == 'log':
                    print(msg[1])
                elif msg[0] == 'stats':
                    board_type = msg[1]
                    stats = msg[2]
                    print(f"[{COLORS[board_type]['name']}] "
                          f"Rate: {stats.rate_hz:.1f} Hz, "
                          f"Captures: {stats.captures}, "
                          f"Peak A: {stats.mean_peak_a:.6f} V, "
                          f"Peak B: {stats.mean_peak_b:.6f} V")
            except queue.Empty:
                pass
                
    except KeyboardInterrupt:
        print("\n" + "="*80)
        print("Stopping acquisitions...")
        
    finally:
        acq_9352.stop()
        acq_9462.stop()
        print("Acquisitions stopped.")
        
    return 0

def run_gui(config_9352: Path, config_9462: Path):
    """Run with full GUI"""
    root = tk.Tk()
    
    # Set application icon (if available)
    try:
        # You can add an icon file here
        # root.iconbitmap('icon.ico')
        pass
    except Exception:
        pass
    
    # Create main GUI
    app = DualBoardGUI(root)
    
    # Load configs if they exist
    if config_9352.exists():
        app.config_path_9352 = config_9352
        app.log_message(f"Loaded 9352 config: {config_9352}")
        
    if config_9462.exists():
        app.config_path_9462 = config_9462
        app.log_message(f"Loaded 9462 config: {config_9462}")
    
    # Handle window close
    def on_closing():
        if app.running:
            if messagebox.askokcancel("Quit", "Acquisition is running. Stop and quit?"):
                app.stop_acquisition()
                root.destroy()
        else:
            root.destroy()
    
    root.protocol("WM_DELETE_WINDOW", on_closing)
    
    # Start GUI event loop
    root.mainloop()
    
    return 0

def main():
    """Main entry point"""
    print("""
    ╔══════════════════════════════════════════════════════════════════════╗
    ║                                                                      ║
    ║                            CAPPY V2                                  ║
    ║                                                                      ║
    ║              ATS-9352 (250 MS/s) + ATS-9462 (180 MS/s)               ║
    ║               Simultaneous dual-board data acquisition               ║
    ║                                                                      ║
    ║                                                                      ║
    ║                                                                      ║
    ╚══════════════════════════════════════════════════════════════════════╝
    """)
    
    # Parse arguments
    args = parse_arguments()
    
    # Create default configs if needed
    create_default_configs()
    
    # Check ATS availability
    if not ATS_AVAILABLE and not args.test:
        print("WARNING: ATS API not available!")
        print("         - Install AlazarTech SDK")
        print("         - Check /usr/local/AlazarTech/samples/Samples_Python/Library/")
        print("         - Or use --test flag for simulated data")
        
        response = input("\nContinue anyway? (y/n): ")
        if response.lower() != 'y':
            return 1
    
    # Run in appropriate mode
    try:
        if args.no_gui:
            return run_headless(args.config_9352, args.config_9462)
        else:
            return run_gui(args.config_9352, args.config_9462)
            
    except Exception as e:
        print(f"\nFATAL ERROR: {e}")
        import traceback
        traceback.print_exc()
        return 1

if __name__ == "__main__":
    sys.exit(main())

class ArchiveViewer:
    """
    Archive viewer window for browsing captured data.
    This is a simplified version - can be expanded with full parquet/sqlite browsing.
    """
    def __init__(self, parent, board_type, data_dir):
        self.board_type = board_type
        self.data_dir = Path(data_dir)
        
        # Create window
        self.window = tk.Toplevel(parent)
        self.window.title(f"{COLORS[board_type]['name']} Archive - {data_dir}")
        self.window.geometry("1200x800")
        self.window.configure(bg='#1e1e1e')
        
        self.setup_ui()
        self.load_sessions()
        
    def setup_ui(self):
        """Build archive viewer UI"""
        # Toolbar
        toolbar = tk.Frame(self.window, bg='#2d2d2d', height=50)
        toolbar.pack(side=tk.TOP, fill=tk.X)
        
        tk.Button(
            toolbar, text="🔄 Refresh",
            command=self.load_sessions,
            bg='#555', fg='white'
        ).pack(side=tk.LEFT, padx=5, pady=5)
        
        tk.Button(
            toolbar, text="📁 Open Data Dir",
            command=self.open_data_dir,
            bg='#555', fg='white'
        ).pack(side=tk.LEFT, padx=5, pady=5)
        
        # Sessions list
        list_frame = tk.Frame(self.window, bg='#1e1e1e')
        list_frame.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=5, pady=5)
        
        tk.Label(
            list_frame, text="Sessions",
            bg='#1e1e1e', fg='white', font=('Arial', 12, 'bold')
        ).pack(anchor='w')
        
        # Scrolled listbox
        scrollbar = tk.Scrollbar(list_frame)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)
        
        self.sessions_listbox = tk.Listbox(
            list_frame,
            bg='#0a0a0a', fg='white',
            font=('Courier', 10),
            yscrollcommand=scrollbar.set
        )
        self.sessions_listbox.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)
        scrollbar.config(command=self.sessions_listbox.yview)
        
        self.sessions_listbox.bind('<<ListboxSelect>>', self.on_session_select)
        
        # Details panel
        details_frame = tk.Frame(self.window, bg='#1e1e1e', width=400)
        details_frame.pack(side=tk.RIGHT, fill=tk.BOTH, padx=5, pady=5)
        details_frame.pack_propagate(False)
        
        tk.Label(
            details_frame, text="Session Details",
            bg='#1e1e1e', fg='white', font=('Arial', 12, 'bold')
        ).pack(anchor='w')
        
        self.details_text = scrolledtext.ScrolledText(
            details_frame,
            bg='#0a0a0a', fg='#00ff00',
            font=('Courier', 9),
            wrap=tk.WORD
        )
        self.details_text.pack(fill=tk.BOTH, expand=True)
        
    def load_sessions(self):
        """Load list of sessions from data directory"""
        self.sessions_listbox.delete(0, tk.END)
        
        if not self.data_dir.exists():
            self.sessions_listbox.insert(tk.END, "Data directory does not exist")
            return
            
        # Find all session directories or parquet files
        sessions = []
        
        # Look for parquet files
        for parquet_file in self.data_dir.glob("**/*.parquet"):
            sessions.append({
                'type': 'parquet',
                'path': parquet_file,
                'name': parquet_file.stem,
                'size': parquet_file.stat().st_size
            })
            
        # Look for session directories with data
        for session_dir in self.data_dir.glob("2*"):  # Sessions starting with year
            if session_dir.is_dir():
                reduced_file = session_dir / "reduced.parquet"
                if reduced_file.exists():
                    sessions.append({
                        'type': 'session',
                        'path': session_dir,
                        'name': session_dir.name,
                        'size': sum(f.stat().st_size for f in session_dir.rglob('*') if f.is_file())
                    })
                    
        # Sort by name (most recent first)
        sessions.sort(key=lambda x: x['name'], reverse=True)
        
        # Display in listbox
        for session in sessions:
            size_str = format_filesize(session['size'])
            display = f"{session['name']:<40} {size_str:>10}"
            self.sessions_listbox.insert(tk.END, display)
            
        self.sessions = sessions
        
        if not sessions:
            self.sessions_listbox.insert(tk.END, "No sessions found")
            
    def on_session_select(self, event):
        """Handle session selection"""
        selection = self.sessions_listbox.curselection()
        if not selection:
            return
            
        idx = selection[0]
        if idx >= len(self.sessions):
            return
            
        session = self.sessions[idx]
        
        # Display session details
        self.details_text.delete('1.0', tk.END)
        self.details_text.insert(tk.END, f"Session: {session['name']}\n")
        self.details_text.insert(tk.END, f"Type: {session['type']}\n")
        self.details_text.insert(tk.END, f"Path: {session['path']}\n")
        self.details_text.insert(tk.END, f"Size: {format_filesize(session['size'])}\n")
        self.details_text.insert(tk.END, "\n")
        
        # Try to load some statistics
        try:
            if session['type'] == 'parquet':
                df = pd.read_parquet(session['path'])
                self.details_text.insert(tk.END, f"Records: {len(df)}\n")
                self.details_text.insert(tk.END, f"Columns: {', '.join(df.columns)}\n")
                self.details_text.insert(tk.END, "\nFirst few records:\n")
                self.details_text.insert(tk.END, str(df.head()))
            elif session['type'] == 'session':
                reduced_file = session['path'] / "reduced.parquet"
                if reduced_file.exists():
                    df = pd.read_parquet(reduced_file)
                    self.details_text.insert(tk.END, f"Records: {len(df)}\n")
                    self.details_text.insert(tk.END, f"Duration: {df['timestamp_ns'].max() - df['timestamp_ns'].min()} ns\n")
                    
        except Exception as e:
            self.details_text.insert(tk.END, f"\nError loading details: {e}\n")
            
    def open_data_dir(self):
        """Open data directory in file browser"""
        if self.data_dir.exists():
            if sys.platform == 'darwin':  # macOS
                subprocess.run(['open', str(self.data_dir)])
            elif sys.platform == 'win32':  # Windows
                os.startfile(str(self.data_dir))
            else:  # Linux
                subprocess.run(['xdg-open', str(self.data_dir)])


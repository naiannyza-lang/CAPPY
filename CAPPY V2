def parse_arguments():
    """Parse command line arguments"""
    parser = argparse.ArgumentParser(
        description="CAPPY Dual-Board Acquisition System",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  # Launch GUI with default configs
  python3 CAPPY_DUAL_BOARD.py
  
  # Specify custom configs
  python3 CAPPY_DUAL_BOARD.py --config-9352 /path/to/9352.yaml --config-9462 /path/to/9462.yaml
  
  # Launch in headless mode (no GUI)
  python3 CAPPY_DUAL_BOARD.py --no-gui --config-9352 config1.yaml --config-9462 config2.yaml

Color Scheme:
  ATS-9352: Pink (#FF00EE) = Channel A, Green (#26FF00) = Channel B
  ATS-9462: Blue (#00BFFF) = Channel A, Orange (#FF8C00) = Channel B
        """
    )
    
    parser.add_argument(
        '--config-9352',
        type=Path,
        default=Path('config_9352.yaml'),
        help='Path to ATS-9352 YAML configuration (default: config_9352.yaml)'
    )
    
    parser.add_argument(
        '--config-9462',
        type=Path,
        default=Path('config_9462.yaml'),
        help='Path to ATS-9462 YAML configuration (default: config_9462.yaml)'
    )
    
    parser.add_argument(
        '--no-gui',
        action='store_true',
        help='Run in headless mode without GUI (for server deployment)'
    )
    
    parser.add_argument(
        '--test',
        action='store_true',
        help='Run in test mode (simulated data, no hardware required)'
    )
    
    return parser.parse_args()

